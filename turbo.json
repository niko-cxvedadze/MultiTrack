{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "INSTANT_APP_ID",
        "INSTANT_APP_ADMIN_TOKEN",
        "SMS_API_KEY",
        "R2_BUCKET_NAME",
        "R2_PUBLIC_URL",
        "NEXT_PUBLIC_INSTANT_APP_ID",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_API_URL_NEW",
        "NEXT_PUBLIC_R2_PUBLIC_URL"
      ]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
