# Vite (apps/admin) - public
VITE_INSTANT_APP_ID=your-instant-app-id
VITE_API_URL=http://localhost:8080
VITE_R2_PUBLIC_URL=https://cdn.example.com

# Next.js (apps/market) - public
NEXT_PUBLIC_INSTANT_APP_ID=your-instant-app-id
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL_NEW=http://localhost:8080
NEXT_PUBLIC_R2_PUBLIC_URL=https://cdn.example.com

# Server-only (shared across all apps)
INSTANT_APP_ID=your-instant-app-id
INSTANT_APP_ADMIN_TOKEN=your-instant-admin-token

# SMS API (sender.ge) - server-only
SMS_API_KEY=your-sms-api-key

# Admin Panel Auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$10$examplehashvalue
JWT_SECRET=your-jwt-secret-min-32-chars
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://cdn.example.com
