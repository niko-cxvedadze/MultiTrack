{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "npx instant-cli push schema --app $INSTANT_APP_ID --token $INSTANT_APP_ADMIN_TOKEN --yes && npx instant-cli push perms --app $INSTANT_APP_ID --token $INSTANT_APP_ADMIN_TOKEN --yes",
    "db:push:schema": "npx instant-cli push schema --app $INSTANT_APP_ID --token $INSTANT_APP_ADMIN_TOKEN --yes",
    "db:push:perms": "npx instant-cli push perms --app $INSTANT_APP_ID --token $INSTANT_APP_ADMIN_TOKEN --yes",
    "db:pull": "npx instant-cli pull --app $INSTANT_APP_ID --token $INSTANT_APP_ADMIN_TOKEN --yes",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.1",
    "@instantdb/react": "^0.22.93",
    "@repo/eslint-config": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.13.1",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^5.0.5",
    "turbo": "^2.4.4",
    "zod": "4.0.2"
  },
  "packageManager": "bun@1.2.4",
  "name": "multitrack",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@instantdb/admin": "^0.22.96",
    "tw-animate-css": "^1.4.0"
  }
}
